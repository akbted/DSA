{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run python",
      "type": "shell",
      "command": "python3",
      "args": ["${file}"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "run python with io",
      "type": "shell",
      "command": "python3 ${file} < ${workspaceFolder}/input.txt > ${workspaceFolder}/output.txt",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}